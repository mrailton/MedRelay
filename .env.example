APP_NAME=MedRelay
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
SECRET_KEY=change-me-to-a-random-secret-key

DATABASE_URL=mysql+pymysql://root@127.0.0.1:3306/medrelay
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30

# Optional: enable multi-worker SSE fan-out (e.g. redis://redis:6379/0)
REDIS_URL=

REALTIME_QUEUE_MAXSIZE=64
REALTIME_MAX_SUBSCRIBERS_PER_CHANNEL=32

SESSION_LIFETIME=120
SESSION_REMEMBER_LIFETIME=43200
SESSION_SECURE_COOKIE=false
